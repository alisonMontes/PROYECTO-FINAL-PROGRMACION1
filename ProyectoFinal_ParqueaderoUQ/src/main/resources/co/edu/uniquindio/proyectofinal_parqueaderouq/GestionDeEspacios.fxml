<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane fx:id="mainStackPane" prefHeight="634.0" prefWidth="988.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.parqueaderouq.parquearoapp.controller.GestionDeEspaciosController">
   <children>
      <Group fx:id="scalingGroup">
         <children>
            <AnchorPane prefHeight="634.0" prefWidth="988.0" style="-fx-background-color: #FFFFFF;">
               <children>
                  <ImageView fitHeight="159.0" fitWidth="425.0" layoutX="282.0" layoutY="49.0">
                     <image>
                        <Image url="@imagenes/img_33.png" />
                     </image>
                  </ImageView>
                  <Text layoutX="355.0" layoutY="139.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Gestion de espacios">
                     <font>
                        <Font name="System Bold" size="30.0" />
                     </font>
                  </Text>

                  <!-- ID Espacio -->
                  <ImageView fitHeight="72.0" fitWidth="233.0" layoutX="94.0" layoutY="250.0">
                     <image>
                        <Image url="@imagenes/img_39.png" />
                     </image>
                  </ImageView>
                  <TextField fx:id="txtIDEspacio" alignment="CENTER" layoutX="94.0" layoutY="250.0" prefHeight="72.0" prefWidth="233.0" promptText="ID Espacio" style="-fx-background-color: transparent;">
                     <font>
                        <Font size="22.0" />
                     </font>
                  </TextField>

                  <!-- Tipo Espacio -->
                  <ImageView fitHeight="72.0" fitWidth="233.0" layoutX="378.0" layoutY="250.0">
                     <image>
                        <Image url="@imagenes/img_39.png" />
                     </image>
                  </ImageView>
                  <ComboBox fx:id="cmbTipoEspacio" layoutX="393.0" layoutY="265.0" prefHeight="42.0" prefWidth="203.0" promptText="Tipo Espacio" style="-fx-background-color: transparent;" />

                  <!-- Estado Espacio -->
                  <ImageView fitHeight="72.0" fitWidth="233.0" layoutX="661.0" layoutY="250.0">
                     <image>
                        <Image url="@imagenes/img_39.png" />
                     </image>
                  </ImageView>
                  <ComboBox fx:id="cmbEstadoEspacio" layoutX="676.0" layoutY="265.0" prefHeight="42.0" prefWidth="203.0" promptText="Estado" style="-fx-background-color: transparent;" />

                  <Button fx:id="btnCrearEspacio" layoutX="102.0" layoutY="380.0" mnemonicParsing="false" onAction="#onCrearEspacio" prefHeight="60.0" prefWidth="233.0" style="-fx-background-color: #84E291;" text="Crear Espacio">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Button>

                  <Button fx:id="btnModificarEspacio" layoutX="378.0" layoutY="380.0" mnemonicParsing="false" onAction="#onModificarEspacio" prefHeight="60.0" prefWidth="233.0" style="-fx-background-color: #84E291;" text="Modificar Espacio">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Button>

                  <Button fx:id="btnEliminarEspacio" layoutX="661.0" layoutY="380.0" mnemonicParsing="false" onAction="#onEliminarEspacio" prefHeight="60.0" prefWidth="233.0" style="-fx-background-color: #84E291;" text="Eliminar Espacio">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Button>

                  <ImageView fitHeight="40.0" fitWidth="71.0" layoutX="22.0" layoutY="22.0">
                     <image>
                        <Image url="@imagenes/img_48.png" />
                     </image>
                  </ImageView>
                  <Button fx:id="btnRegresarMenuAdmin" layoutX="32.0" layoutY="22.0" mnemonicParsing="false" onAction="#onRegresarMenuAdmin" opacity="0.0" prefHeight="40.0" prefWidth="52.0" text="Regresar" />

                  <ImageView fitHeight="82.0" fitWidth="71.0" layoutX="474.0" layoutY="529.0">
                     <image>
                        <Image url="@imagenes/pngwing.com.png" />
                     </image>
                  </ImageView>
                  <ImageView fitHeight="52.0" fitWidth="52.0" layoutX="908.0" layoutY="551.0">
                     <image>
                        <Image url="@imagenes/img_50.png" />
                     </image>
                  </ImageView>
                  <Button fx:id="btnMostarListaDeespacios" layoutX="908.0" layoutY="551.0" mnemonicParsing="false" onAction="#onMostarListaDeespacios" opacity="0.0" prefHeight="52.0" prefWidth="52.0" text="Button" />
               </children>
            </AnchorPane>
         </children>
      </Group>
   </children>
</StackPane>
