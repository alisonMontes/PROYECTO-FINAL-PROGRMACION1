<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Group?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="mainStackPane" prefHeight="634.0" prefWidth="988.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.parqueaderouq.parquearoapp.controller.ListaUsuariosController">
   <children>
      <Group fx:id="scalingGroup">
         <children>
            <AnchorPane prefHeight="634.0" prefWidth="988.0" style="-fx-background-color: #FFFFFF;">
               <children>
                  <VBox alignment="TOP_CENTER" layoutX="62.0" layoutY="109.0" prefHeight="503.0" prefWidth="862.0" spacing="20.0">
                     <children>
                        <TableView fx:id="tblUsuarios" prefHeight="498.0" prefWidth="820.0" style="-fx-border-color: #84E291;">
                          <columns>
                            <TableColumn fx:id="colNombre" prefWidth="150.0" style="-fx-background-color: #FFFFFF;" text="Nombre" />
                            <TableColumn fx:id="colID" prefWidth="150.0" style="-fx-background-color: #FFFFFF;" text="Identificación" />
                            <TableColumn fx:id="colCorreo" prefWidth="200.0" style="-fx-background-color: #FFFFFF;" text="Correo" />
                            <TableColumn fx:id="colTelefono" prefWidth="120.0" style="-fx-background-color: #FFFFFF;" text="Teléfono" />
                            <TableColumn fx:id="colTipo" prefWidth="130.0" style="-fx-background-color: #FFFFFF;" text="Tipo de Usuario" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
                  <ImageView fitHeight="77.0" fitWidth="358.0" layoutX="315.0" layoutY="13.0">
                     <image>
                        <Image url="@imagenes/img_39.png" />
                     </image>
                  </ImageView>
                  <Label layoutX="374.0" layoutY="34.0" text="Usuarios Registrados">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <ImageView fitHeight="77.0" fitWidth="71.0" layoutX="890.0" layoutY="19.0">
                     <image>
                        <Image url="@imagenes/pngwing.com.png" />
                     </image>
                  </ImageView>
               </children>
            </AnchorPane>
         </children>
      </Group>
   </children>
</StackPane>
